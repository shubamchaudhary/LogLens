# ============================================================
# ChunkAI — environment template
# Copy to .env and fill in:   cp .env.example .env
# .env is gitignored — never commit real keys.
#
# Docker Compose reads .env automatically.
# `gradlew bootRun` does NOT — load it first (PowerShell):
#   Get-Content .env | Where-Object {$_ -match '^[^#].*='} | ForEach-Object { $n,$v = $_ -split '=',2; [Environment]::SetEnvironmentVariable($n,$v) }
# or set the vars in your IDE run configuration.
# ============================================================

# ── LLM providers ────────────────────────────────────────────
# Chat: groq (default) or gemini. Embeddings are SPLIT from chat
# because Groq serves no embedding models (2026-07) — they default
# to gemini. Backend and orchestrator MUST agree on both values;
# embeddings from different models don't mix.
LLM_PROVIDER=groq
EMBEDDING_PROVIDER=gemini

# ── Groq (REQUIRED — chat/enrichment/correlation) ────────────
# Free key at https://console.groq.com/ — 30 RPM / 14,400 RPD on
# llama-3.1-8b-instant (note: 6K tokens/min is the real throttle).
# One key is plenty; add comma-separated keys for more lanes.
GROQ_API_KEY=gsk_your_key_here
# GROQ_API_KEYS=gsk_key1,gsk_key2

# ── Gemini (REQUIRED — embeddings; gemini-embedding-001 @ 768) ─
# Free key at https://aistudio.google.com/ — one key is enough for
# embeddings (Google's RPD crackdown hit text-out models, not
# embeddings). Also the fallback chat provider (LLM_PROVIDER=gemini).
GEMINI_API_KEY=your_gemini_key_here
# GEMINI_API_KEYS=key1,key2,key3,key4,key5

# ── Security (REQUIRED — change it) ─────────────────────────
# Min 256 bits. Generate one (PowerShell):
#   -join ((48..57)+(97..122) | Get-Random -Count 64 | ForEach-Object {[char]$_})
JWT_SECRET=change-me-to-a-long-random-string-of-at-least-64-characters

# ── Infrastructure (defaults match docker-compose; only change
#    if you changed the compose file) ─────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
ORCHESTRATOR_URL=http://localhost:8000

# ── Orchestrator, only when run OUTSIDE docker (python -m uvicorn) ──
# Inside docker-compose these are set on the service already.
# Note the port: 5434 from host, 5432 from inside compose.
DATABASE_URL=postgresql://deepdocai:deepdocai123@localhost:5434/deepdocai_db
# Optional model overrides:
# ORCH_GEN_MODEL=gemini-2.5-flash
# ORCH_EMBED_MODEL=models/text-embedding-004
